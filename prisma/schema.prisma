generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      String    @default("OPERATOR")
  name      String?
  createdAt DateTime  @default(now())
  auditLogs AuditLog[]
  preferences String?
}

model Marketplace {
  id                     String                  @id @default(uuid())
  key                    String                  @unique
  name                   String
  apiKey                 String?
  apiSecret              String?
  apiUrl                 String?
  apiStatus              String                  @default("unknown")
  active                 Boolean                 @default(true)
  merchantId             String?
  storeId                String?
  settings               String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  productMarketplaceStates ProductMarketplaceState[]
  orders                 Order[]
  messages               Message[]
  templates              ListingTemplate[]
  financeRecords         FinanceRecord[]
  categoryMappings       CategoryMapping[]
}

model Product {
  id                     String                  @id @default(uuid())
  xmlKey                 String                  @unique
  title                  String?
  seoTitle               String?
  seoDescription         String?
  description            String?
  technicalSpecs         String?
  images                 String?
  videos                 String?
  sku                    String?
  barcode                String?
  stockCode              String?
  categoryId             String?
  category               Category?               @relation(fields: [categoryId], references: [id])
  brandId                String?
  brand                  Brand?                  @relation(fields: [brandId], references: [id])
  categoryMatch          Boolean                 @default(false)
  variantMatch           Boolean                 @default(false)
  variantStatus          String                  @default("WAITING_AI")
  brandMatch             Boolean                 @default(false)
  templateMatch          Boolean                 @default(false)
  stock                  Int                     @default(0)
  minStock               Int                     @default(0)
  criticalStockLevel     Int?
  autoStockManagement    Boolean                 @default(false)
  lastStockCheckAt       DateTime?
  purchasePrice          Float?
  salePrice              Float?
  vatRate                Float?
  commissionRate         Float?
  profitMargin           Float?
  minProfit              Float?
  discount               Float?
  status                 String                  @default("XML")
  errorMessage           String?
  tags                   String?
  xmlSourceId            String?
  link                   String?
  unit                   String?
  currency               String?
  detail                 String?
  supplierCategory       String?
  brandUsageType         String   @default("XML_BRAND") // XML_BRAND | DG_BRAND | CUSTOM
  customBrandName        String?  // Özel marka adı (CUSTOM seçildiğinde)
  prefixEnabled          Boolean  @default(false) // Ön ek aktif mi?
  originalTitle          String?  // Orijinal XML başlığı (korunur)
  computedTitle          String?  // Ön ek uygulanmış başlık
  aiSuggestedCategoryId  String?
  aiScore                Float?
  matchedBy              String?
  lastMatchDate          DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  marketplaceStates      ProductMarketplaceState[]
  variants               Variant[]
  xmlSource              XmlSource?              @relation(fields: [xmlSourceId], references: [id])

  @@index([variantMatch])
  @@index([xmlSourceId])
  @@index([categoryId])
  @@index([brandId])
  @@index([status])
}

model ProductMarketplaceState {
  id             String        @id @default(uuid())
  productId      String
  marketplaceId  String
  status         String        @default("XML")
  listingId      String?
  listingUrl     String?
  lastActionAt   DateTime?
  externalRef    String?
  price          Float?
  stock          Int?
  errorMessage   String?

  product       Product       @relation(fields: [productId], references: [id])
  marketplace   Marketplace   @relation(fields: [marketplaceId], references: [id])

  @@unique([productId, marketplaceId])
}

model QueueJob {
  id            String   @id @default(uuid())
  jobType       String
  idempotencyKey String  @unique
  status        String   @default("queued")
  attempts      Int      @default(0)
  lastError     String?
  payload       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model XmlSource {
  id                      String           @id @default(uuid())
  name                    String
  company                 String?
  sourceType              String           @default("MANUAL")
  url                     String?
  username                String?
  password                String?
  currency                String           @default("TRY")
  vatRate                 Float            @default(20)
  updateStock             Boolean          @default(true)
  updatePrice             Boolean          @default(true)
  updateImages            Boolean          @default(true)
  active                  Boolean          @default(true)
  scheduleIntervalMinutes Int              @default(60)
  cronExpression          String?
  lastRunAt               DateTime?
  lastSuccessAt           DateTime?
  lastError               String?
  connectionStatus        String           @default("unknown")
  purchasePriceVatStatus  String           @default("dahil")
  pricingRules            String?
  fieldMapping            String?
  purchasePriceField      String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  importRuns              XmlImportRun[]
  products                Product[]
  xmlProfile              XmlProfile?         // V4: XML profili
  variantFamilies         VariantFamily[]     // V4: oluşturulan aileler
}

model XmlImportRun {
  id                  String                 @id @default(uuid())
  sourceId            String
  startedAt           DateTime               @default(now())
  finishedAt          DateTime?
  durationMs          Int?
  status              String                 @default("running")
  totalProducts       Int                    @default(0)
  newProducts         Int                    @default(0)
  updatedProducts     Int                    @default(0)
  failedProducts      Int                    @default(0)
  skippedProducts     Int                    @default(0)
  deletedProducts     Int                    @default(0)
  errorDetail         String?
  source              XmlSource              @relation(fields: [sourceId], references: [id])
  itemResults         XmlImportItemResult[]
}

model XmlImportItemResult {
  id              String        @id @default(uuid())
  importRunId     String
  xmlKey          String
  sku             String?
  outcome         String        @default("created")
  errorDetail     String?
  createdAt       DateTime      @default(now())
  importRun       XmlImportRun  @relation(fields: [importRunId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  entity      String?
  entityId    String?
  meta        String?
  details     String?
  ipAddress   String?
  duration    Int?
  success     Boolean  @default(true)
  createdAt   DateTime @default(now())

  actorUser   User? @relation(fields: [actorUserId], references: [id])
}

model Category {
  id              String    @id @default(uuid())
  name            String    @unique
  externalId      String?
  parentId        String?
  parent          Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children        Category[] @relation("CategoryHierarchy")
  variantRequired Boolean   @default(true)
  products        Product[]
  mappings        CategoryMapping[] @relation("CategoryMappings")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model CategoryMapping {
  id              String    @id @default(uuid())
  categoryId      String
  category        Category  @relation("CategoryMappings", fields: [categoryId], references: [id])
  marketplaceId   String?
  marketplace     Marketplace? @relation(fields: [marketplaceId], references: [id])
  externalId      String?
  externalName    String?
  externalPath    String?
  source          String    @default("manual") // "manual", "xml", "ai", "marketplace"
  confidence      Float?    // AI confidence score
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([categoryId, marketplaceId, source])
}

model Brand {
  id            String          @id @default(uuid())
  name          String          @unique
  externalId    String?
  logo          String?         // Marka logosu URL
  prefixEnabled Boolean         @default(false) // Ön ek aktif mi?
  prefixFormat  String          @default("MARKA® {title}") // Ön ek formatı
  isActive      Boolean         @default(true)
  products      Product[]
  brandMappings BrandMapping[]  // XML marka eşleştirmeleri
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model BrandMapping {
  id            String    @id @default(uuid())
  xmlBrandName  String    @unique // XML'den gelen orijinal marka adı (örn: "NIKE", "NİKE")
  dgBrandId     String    // Bağlandığı DG STOK markası ID
  dgBrand       Brand     @relation(fields: [dgBrandId], references: [id])
  confidence    Float?    // AI güven skoru (0-100)
  isAuto        Boolean   @default(false) // Otomatik eşleşti mi?
  productCount  Int       @default(0) // Bu XML markasına sahip ürün sayısı
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model BrandLog {
  id            String    @id @default(uuid())
  action        String    // BRAND_MATCH, BRAND_UNMATCH, PREFIX_APPLY, PREFIX_REMOVE, BULK_CHANGE, AI_MATCH, UNDO
  xmlBrandName  String?   // XML markası
  dgBrandId     String?   // Hedef DG STOK markası ID
  dgBrandName   String?   // Hedef marka adı (log okunabilirliği için)
  oldValue      String?   // Eski değer
  newValue      String?   // Yeni değer
  prefixChanged Boolean   @default(false)
  productCount  Int       @default(0) // Etkilenen ürün sayısı
  details       String?   // İşlem detayı (JSON)
  actorUserId   String?   // Kullanıcı ID'si (relationsız, basit tutuldu)
  createdAt     DateTime  @default(now())
}

model Variant {
  id          String    @id @default(uuid())
  name        String
  value       String
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, name, value])
  @@index([name])
  @@index([productId])
}

model Order {
  id            String    @id @default(uuid())
  orderNo       String    @unique
  channel       String
  marketplaceId String?
  marketplace   Marketplace? @relation(fields: [marketplaceId], references: [id])
  customerName  String
  customerEmail String?
  customerPhone String?
  address       String?
  city          String?
  district      String?
  cargoCompany  String?
  trackingNo    String?
  status        String    @default("new")
  total         Float
  cargoPrice    Float?
  commission    Float?
  vat           Float?
  notes         String?
  items         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  shipments     Shipment[]
  financeRecords FinanceRecord[]
}

model Shipment {
  id            String    @id @default(uuid())
  orderId       String?
  order         Order?    @relation(fields: [orderId], references: [id])
  channel       String
  cargoCompany  String
  trackingNo    String
  status        String    @default("queued")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Message {
  id            String    @id @default(uuid())
  marketplaceId String?
  marketplace   Marketplace? @relation(fields: [marketplaceId], references: [id])
  customerName  String
  customerEmail String?
  subject       String
  message       String
  aiSuggestion  String?
  status        String    @default("unread")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Notification {
  id          String    @id @default(uuid())
  type        String
  title       String
  message     String
  read        Boolean   @default(false)
  userId      String?
  createdAt   DateTime  @default(now())
}

model ListingTemplate {
  id            String    @id @default(uuid())
  name          String
  marketplaceId String?
  marketplace   Marketplace? @relation(fields: [marketplaceId], references: [id])
  titleFormat   String?
  description   String?
  priceFormula  String?
  commissionRate Float?
  vatRate       Float?
  cargoSettings String?
  imageSettings String?
  productId     String?
  categoryId    String?
  brandId       String?
  variantSettings String?
  active        Boolean   @default(true)

  // === V3 ENTERPRISE ALANLARI ===

  // --- Fiyat Motoru ---
  priceSource        String  @default("XML_PURCHASE") // XML_PURCHASE | XML_SALE | FIXED | AI_CALCULATE
  vatMode            String  @default("INCLUDED")     // INCLUDED | EXCLUDED | BY_CATEGORY | AUTO
  priceMultiplier    Float   @default(1.0)            // x1.20, %180 => 1.8 olarak
  priceFixedAmount   Float   @default(0)              // +0 TL ila +100 TL
  priceRangeRules    String? // JSON: [{min:0, max:100, multiplier:2.2, fixedAmount:20}, ...]

  // --- Dışlama (Exclude) Kuralları ---
  excludeRules       String? // JSON: {categories:[], brands:[], suppliers:[], products:[], skus:[], barcodes:[]}

  // --- Başlık Şablonu V3 ---
  titleVariables     String? // JSON: variableId yapılandırması
  titleMaxLength     Int?    // Karakter limiti
  titleSeoMaxLength  Int?    // SEO karakter limiti

  // --- Açıklama Şablonu V3 ---
  descriptionBlocks  String? // JSON: [{type:'text'|'table'|'list'|'techspecs'|'ai'|'block', content:'...'}, ...]
  descriptionMaxLength Int?  // Karakter limiti

  // --- Görsel Kuralları V3 ---
  imageMinCount      Int?    // Minimum görsel sayısı
  imageMaxCount      Int?    // Maksimum görsel sayısı
  imageOrder         String? // SEQUENTIAL | RANDOM | MANUAL
  imageWatermark     String? // Filigran metni veya URL
  imageBackground    String? // WHITE | TRANSPARENT | COLOR
  imageMinSize       Int?    // Minimum piksel (örn: 800)
  imageFormat        String? // JPEG | PNG | WEBP

  // --- Stok Kuralları ---
  stockMultiplier    Int?    // Stok çarpanı (örn: 5)
  stockMinValue      Int?    // Minimum stok
  stockMaxValue      Int?    // Maksimum stok
  stockHide          Boolean @default(false) // Stok sıfırsa gizle
  stockAutoDeactivate Boolean @default(false) // Stok sıfırsa otomatik pasife al

  // --- Barkod Kuralları ---
  barcodePrefix      String? // Barkod ön eki
  barcodeSuffix      String? // Barkod son eki
  barcodeAutoGenerate Boolean @default(false) // Barkod yoksa otomatik üret

  // --- Doğrulama ---
  validationRules    String? // JSON: etkin doğrulama kuralları dizisi

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model AutomationRule {
  id            String    @id @default(uuid())
  name          String
  type          String
  triggerType   String
  triggerConfig String?
  actionType    String
  actionConfig  String?
  active        Boolean   @default(true)
  schedule      String?
  marketplaceId String?
  lastRunAt     DateTime?
  lastSuccessAt DateTime?
  lastError     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model TransformationLog {
  id          String   @id @default(uuid())
  productId   String
  xmlSourceId String?
  action      String   // TRANSFORM, CLEAN, AI_SUGGEST, BULK_CONVERT, UNDO, REDO
  oldTitle    String?
  newTitle    String?
  oldBrand    String?
  newBrand    String?
  oldBrandId  String?
  newBrandId  String?
  stepType    String?  // BRAND, TITLE, CLEAN, SEO
  details     String?  // JSON
  actorUserId String?
  createdAt   DateTime @default(now())
}

model FinanceRecord {
  id            String      @id @default(uuid())
  type          String      @default("sale")
  amount        Float
  commission    Float?
  vat           Float?
  profit        Float?
  productId     String?
  marketplaceId String?
  marketplace   Marketplace? @relation(fields: [marketplaceId], references: [id])
  orderId       String?
  order         Order?      @relation(fields: [orderId], references: [id])
  description   String?
  date          DateTime    @default(now())
  createdAt     DateTime    @default(now())
}

model BrandPolicy {
  id              String    @id @default(uuid())
  name            String    // Politika adı
  policyType      Int       // 1-7 arası politika tipi
  xmlSourceId     String?   // Hangi XML kaynağı için (null = tümü)
  dgBrandId       String?   // Kullanılacak DG STOK markası
  prefixFormat    String?   // Ön ek formatı (Politika 4,6,7 için)
  separator       String    @default(" | ") // Ayraç (Politika 5 için)
  removeXmlBrand  Boolean   @default(false) // XML markayı temizle (Politika 7)
  isActive        Boolean   @default(true)
  priority        Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model TitleTemplate {
  id            String    @id @default(uuid())
  name          String    // Şablon adı
  template      String    // "{BRAND}® {PRODUCT_NAME} | {COLOR}"
  xmlSourceId   String?   // XML kaynağı (null=tümü)
  brandId       String?   // Marka (null=tümü)
  categoryId    String?   // Kategori (null=tümü)
  marketplaceId String?   // Pazaryeri (null=tümü)
  priority      Int       @default(0)
  isActive      Boolean   @default(true)
  maxLength     Int?      // Karakter limiti
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ==================== AI CONTENT COMPLIANCE ENGINE ====================

model ForbiddenWord {
  id            String    @id @default(uuid())
  word          String    @unique
  category      String    @default("OTHER") // MARKETING | SWEAR | COMMUNICATION | COMPETITOR | SPAM | OTHER
  riskLevel     String    @default("HIGH") // LOW | MEDIUM | HIGH | CRITICAL
  marketplaces  String?   // JSON array
  isActive      Boolean   @default(true)
  autoFix       String?   // Otomatik düzeltme metni
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ForbiddenWordGroup {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  words       String?  // JSON array
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model MarketplaceContentProfile {
  id                String   @id @default(uuid())
  marketplaceKey    String   @unique
  marketplaceName   String

  // Başlık
  maxTitleLength    Int      @default(150)
  minTitleLength    Int      @default(10)
  forbiddenChars    String?  // JSON
  emojiPolicy       String   @default("REMOVE")
  maxUppercaseRatio Float    @default(0.3)

  // HTML
  allowHtml         Boolean  @default(false)
  allowedHtmlTags   String?  // JSON

  // Görsel
  minImageWidth     Int      @default(800)
  minImageHeight    Int      @default(800)
  maxImageWidth     Int      @default(5000)
  maxImageHeight    Int      @default(5000)
  whiteBackground   Boolean  @default(true)

  // Barkod
  barcodeRequired   Boolean  @default(true)
  barcodeFormat     String?

  requiredAttributes String? // JSON
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ContentAnalysisResult {
  id              String   @id @default(uuid())
  productId       String
  marketplaceKey  String?

  // Skorlar
  totalScore      Int      @default(0)
  titleScore      Int      @default(100)
  descScore       Int      @default(100)
  imageScore      Int      @default(100)
  barcodeScore    Int      @default(100)
  priceScore      Int      @default(100)

  // Sorunlar
  issues          String?  // JSON
  aiSuggestions   String?  // JSON
  autoFixed       Boolean  @default(false)
  fixLog          String?  // JSON

  // AI önerileri
  aiConfidence    Int      @default(0)
  aiSuggestedTitle String?
  aiSuggestedDesc  String?

  status          String   @default("PENDING") // PENDING | AUTO_FIXED | AWAITING_APPROVAL | FAILED | PASSED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([productId])
  @@index([status])
}

model ApiErrorLog {
  id              String   @id @default(uuid())
  productId       String
  marketplaceKey  String
  errorCode       String
  errorMessage    String
  rejectedField   String?  // title | description | image | price
  aiLearnedRule   String?  // AI öğrenilen kural
  applied         Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model WorkflowState {
  id          String   @id @default(uuid())
  productId   String   @unique
  status      String   @default("IMPORTED")
  readiness   Int      @default(0)
  stepCategory String? // OK, MISSING, AUTO_FIXED
  stepBrand   String?
  stepVariant String?
  stepTitle   String?
  stepSeo     String?
  stepPrice   String?
  stepImage   String?
  stepBarcode String?
  stepStock   String?
  errorCount  Int      @default(0)
  lastError   String?
  aiSuggested Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkflowTimeline {
  id          String   @id @default(uuid())
  productId   String
  event       String
  details     String?
  actorUserId String?
  createdAt   DateTime @default(now())
}

model MarketplaceTitleConfig {
  id            String    @id @default(uuid())
  key           String    @unique // trendyol, amazon, n11, hepsiburada
  name          String
  logo          String?
  maxLength     Int       @default(150)
  seoMaxLength  Int       @default(70)
  createdAt     DateTime  @default(now())
}

model AIKnowledge {
  id          String   @id @default(uuid())
  module      String   // CATEGORY, BRAND, TITLE, SEO, ATTRIBUTE, VARIANT
  input       String   // Girdi
  output      String   // Çıktı
  confidence  Float    @default(0)
  useCount    Int      @default(0)
  acceptCount Int      @default(0)
  rejectCount Int      @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([module, input, output])
}

model AIUserPolicy {
  id                 String   @id @default(uuid())
  module             String   @unique
  autoApplyThreshold Int      @default(95)
  requireApproval    Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AIDecisionLog {
  id          String   @id @default(uuid())
  productId   String
  module      String
  suggestion  String
  confidence  Float
  reason      String?
  autoApplied Boolean  @default(false)
  accepted    Boolean?
  actorUserId String?
  createdAt   DateTime @default(now())
}

model ProductHistory {
  id          String   @id @default(uuid())
  productId   String
  field       String   // status, brandId, categoryId, salePrice, stock, title
  oldValue    String?
  newValue    String?
  action      String   // XML_IMPORT, CATEGORY_MATCH, BRAND_MATCH, TITLE_UPDATE, PRICE_UPDATE, STOCK_UPDATE
  actorUserId String?
  createdAt   DateTime @default(now())
}

// ==================== VARYANT EŞLEŞTİRME MERKEZİ V6.0 ====================

model VariantPool {
  id          String   @id @default(uuid())
  parentSku   String
  productId   String?
  totalChildren Int    @default(0)
  status      String   @default("pending") // pending, partial, ready, error
  source      String?  // XML'den gelen kaynak (manual, ai, auto)
  scannedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentSku])
  @@index([status])
}

model MarketplaceVariantRule {
  id                String   @id @default(uuid())
  marketplaceKey    String   @unique
  marketplaceName   String
  requiredAttributes String  // JSON array: ["Renk", "Beden"]
  optionalAttributes String  // JSON array: ["Numara", "Cinsiyet"]
  maxVariantsPerGroup Int    @default(100)
  variantGroupRequired Boolean @default(true)
  colorMapping      String?  // JSON object for color translations
  sizeMapping       String?  // JSON object for size translations
  attributeRules    String?  // JSON: her attribute için kurallar
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model VariantMapping {
  id              String   @id @default(uuid())
  xmlValue        String   // XML'den gelen orijinal değer
  attributeType   String   // Renk, Beden, Numara, vb.
  mappedValue     String   // Eşleştirilen değer
  marketplaceKey  String?  // Hangi pazaryeri için (null = evrensel)
  confidence      Float?   // AI güven skoru
  source          String   @default("manual") // manual, ai, auto, pattern
  useCount        Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([xmlValue, attributeType, marketplaceKey])
  @@index([attributeType])
  @@index([marketplaceKey])
}

model VariantValidationLog {
  id              String   @id @default(uuid())
  productId       String
  parentSku       String?
  score           Int      @default(0)
  status          String   // ready, needs_review, blocked
  errors          String?  // JSON array of error messages
  checks          String?  // JSON: {checkName: boolean}
  marketplaceKey  String?
  validatedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
}
model Rule {
  id            String   @id @default(uuid())
  name          String
  description   String?
  category      String   // CATEGORY, BRAND, TITLE, SEO, PRICE, STOCK
  condition     String   // JSON: { field, operator, value }
  action        String   // JSON: { type, value }
  priority      Int      @default(0)
  isActive      Boolean  @default(true)
  version       Int      @default(1)
  xmlSourceId   String?
  brandId       String?
  categoryId    String?
  marketplaceId String?
  testResult    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RuleLog {
  id        String   @id @default(uuid())
  ruleId    String
  productId String
  result    String   // APPLIED, SKIPPED, ERROR
  details   String?
  createdAt DateTime @default(now())
}

// ==================== VARYANT MOTORU V4.0 ====================
// Universal XML Profile Engine + Smart Variant Engine

model VariantAnalysis {
  id                String   @id @default(uuid())
  productId         String
  confidence        Int      // 0-100 güven skoru
  source            String   // XML_PARENT | AI_MATCH | AUTO_CREATED | MANUAL | NO_VARIANT_NEEDED
  status            String   // AUTO_ACCEPTED | AUTO_CREATED | RE_ANALYZED | MANUAL_REVIEW | ERROR
  reason            String?  // Hata/uyarı sebebi
  parentSku         String?  // Otomatik oluşturulan parent SKU
  groupId           String?  // Varyant grup ID'si
  xmlHasParent      Boolean  @default(false)
  checkResults      String?  // JSON
  autoFixAttempted  Boolean  @default(false) // V4: otomatik düzeltme denendi mi?
  autoFixResult     String?  // V4: JSON - düzeltme sonucu
  validationPassed  Boolean  @default(false) // V4: doğrulama geçti mi?
  familyId          String?  // V4: ürün ailesi ID'si
  profileApplied    Boolean  @default(false) // V4: XML profili kullanıldı mı?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([productId])
  @@index([status])
  @@index([confidence])
  @@index([familyId])
}

// V4: XML Profil - Her XML kaynağının profili
model XmlProfile {
  id                String   @id @default(uuid())
  xmlSourceId       String   @unique
  profileName       String?
  xmlType           String?  // DISTRIBUTED_VARIANT | SIMPLE | FLAT | UNKNOWN

  // XML Analiz Sonuçları
  hasParentSku       Boolean  @default(false)
  parentSkuUsageRate Float    @default(0)
  hasGroupId         Boolean  @default(false)
  groupIdUsageRate   Float    @default(0)
  hasVariationTheme  Boolean  @default(false)
  variationThemeRate Float    @default(0)
  hasColor           Boolean  @default(false)
  colorUsageRate     Float    @default(0)
  hasSize            Boolean  @default(false)
  sizeUsageRate      Float    @default(0)
  hasNumber          Boolean  @default(false)
  numberUsageRate    Float    @default(0)
  hasModel           Boolean  @default(false)
  modelUsageRate     Float    @default(0)
  barcodeUsageRate   Float    @default(0)
  skuUsageRate       Float    @default(0)

  // Kalite Skorları (0-100)
  titleQuality       Int      @default(0)
  categoryQuality    Int      @default(0)
  attributeQuality   Int      @default(0)

  // DG STOK Karar
  dgMode             String   @default("AUTO") // AUTO | SEMI_AUTO | MANUAL
  canAutoCreate      Boolean  @default(false)
  lastAnalysisDate   DateTime?

  // Öğrenilen Kurallar
  learnedRules       String?  // JSON
  confidence         Float    @default(0)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  xmlSource          XmlSource @relation(fields: [xmlSourceId], references: [id])
}

// V4: Ürün Ailesi - DG STOK'un oluşturduğu varyant aileleri
model VariantFamily {
  id              String   @id @default(uuid())
  parentSku       String   @unique
  groupId         String?
  generatedBy     String   @default("DG_AUTO") // XML | DG_AUTO | MANUAL
  productCount    Int      @default(0)
  marketplaceKey  String?
  isActive        Boolean  @default(true)
  xmlSourceId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members VariantFamilyMember[]
  xmlSource XmlSource? @relation(fields: [xmlSourceId], references: [id])
}

// V4: Ürün Ailesi Üyeleri
model VariantFamilyMember {
  id              String   @id @default(uuid())
  familyId        String
  productId       String
  attributeName   String?  // Renk, Beden, Numara, Desen, Materyal
  attributeValue  String?
  confidence      Int      @default(0)
  assignedBy      String   @default("DG_AUTO") // XML | DG_AUTO | AI | MANUAL
  createdAt       DateTime @default(now())

  family VariantFamily @relation(fields: [familyId], references: [id])

  @@unique([familyId, productId])
  @@index([familyId])
  @@index([productId])
}

model VariantThreshold {
  id        String   @id @default(uuid())
  key       String   @unique // auto_accept | auto_create | re_analyze | auto_suggest | manual
  value     Int               // eşik değeri (95, 90, 80, 70, 0)
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ==================== AI PRODUCTION CENTER TABLOLARI ====================

model AICheck {
  id                    String   @id @default(uuid())
  productId             String   @unique
  categoryStatus        String   @default("PENDING") // OK | WARNING | ERROR | PENDING
  brandStatus           String   @default("PENDING")
  variantStatus         String   @default("PENDING")
  barcodeStatus         String   @default("PENDING")
  imageStatus           String   @default("PENDING")
  titleStatus           String   @default("PENDING")
  descriptionStatus     String   @default("PENDING")
  seoStatus             String   @default("PENDING")
  priceStatus           String   @default("PENDING")
  stockStatus           String   @default("PENDING")
  listingTemplateStatus String   @default("PENDING")
  workflowStatus        String   @default("PENDING")
  overallScore          Int      @default(0)
  overallStatus         String   @default("ERROR") // PERFECT | GOOD | WARNING | ERROR
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AITask {
  id             String    @id @default(uuid())
  productId      String
  taskType       String    // CATEGORY | BRAND | VARIANT | TITLE | SEO | DESCRIPTION | IMAGE | PRICE
  currentValue   String?
  suggestedValue String?
  confidence     Float?
  status         String    @default("PENDING") // PENDING | APPROVED | REJECTED | APPLIED
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([productId])
  @@index([taskType])
  @@index([status])
}

model AIJob {
  id             String    @id @default(uuid())
  jobType        String    // FULL_SCAN | CATEGORY_SCAN | BRAND_SCAN
  status         String    @default("PENDING") // PENDING | RUNNING | COMPLETED | FAILED
  progress       Int       @default(0)
  processedCount Int       @default(0)
  totalCount     Int       @default(0)
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())
}

model AIReport {
  id              String   @id @default(uuid())
  scanDate        DateTime @default(now())
  totalProducts   Int      @default(0)
  healthyProducts Int      @default(0)
  warningProducts Int      @default(0)
  errorProducts   Int      @default(0)
  averageScore    Float    @default(0)
  createdAt       DateTime @default(now())
}

model AICategorySuggestion {
  id                  String   @id @default(uuid())
  productId           String
  marketplace         String   @default("trendyol")
  currentCategory     String?
  currentCategoryId   String?
  suggestedCategory   String?
  suggestedCategoryId String?
  confidence          Float?
  reason              String?
  approved            Boolean  @default(false)
  approvedAt          DateTime?
  createdAt           DateTime @default(now())

  @@index([productId])
  @@index([marketplace])
  @@index([confidence])
}

model AIBrandSuggestion {
  id              String    @id @default(uuid())
  productId       String
  currentBrand    String?
  suggestedBrand  String?
  confidence      Float?
  reason          String?
  approved        Boolean   @default(false)
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([productId])
  @@index([approved])
}

model AIVariantSuggestion {
  id             String    @id @default(uuid())
  productId      String
  variantType    String    // RENK | BEDEN | NUMARA | BOYUT | MODEL
  currentValue   String?
  suggestedValue String?
  confidence     Float?
  reason         String?
  approved       Boolean   @default(false)
  approvedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([productId])
  @@index([variantType])
  @@index([approved])
}

model AIContentSuggestion {
  id                 String    @id @default(uuid())
  productId          String
  marketplace        String    @default("trendyol")
  currentTitle       String?
  suggestedTitle     String?
  currentDescription String?
  suggestedDescription String?
  keywords           String?   // JSON array
  forbiddenWords     String?   // JSON array
  titleScore         Int       @default(0)
  descriptionScore   Int       @default(0)
  seoScore           Int       @default(0)
  overallScore       Int       @default(0)
  confidence         Float?
  approved           Boolean   @default(false)
  approvedAt         DateTime?
  createdAt          DateTime  @default(now())

  @@index([productId])
  @@index([marketplace])
}

model AIProvider {
  id              String    @id @default(uuid())
  name            String    @unique // deepseek | openai | gemini | kimi | claude | mock
  enabled         Boolean   @default(true)
  priority        Int       @default(1)
  apiKeyEncrypted String?
  baseUrl         String?
  model           String?
  dailyTokenLimit Int       @default(1000000)
  usedTokens      Int       @default(0)
  estimatedCost   Float     @default(0)
  status          String    @default("unknown") // unknown | healthy | error | rate_limited
  lastCheck       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AIRequestLog {
  id              String   @id @default(uuid())
  provider        String
  module          String   // category | brand | variant | content | pricing
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  totalTokens     Int      @default(0)
  estimatedCost   Float    @default(0)
  duration        Int      @default(0) // ms
  success         Boolean  @default(true)
  error           String?
  createdAt       DateTime @default(now())

  @@index([provider])
  @@index([module])
  @@index([createdAt])
}

model AIIssue {
  id                String    @id @default(uuid())
  productId         String
  module            String    // category | brand | variant | content | image | price | workflow | marketplace | xml
  type              String    // CATEGORY_MISSING | BRAND_MISSING | VARIANT_MISSING | CONTENT_MISSING | SEO_LOW | IMAGE_LOW | PRICE_RISK | WORKFLOW_BLOCKED | READY_TO_SEND_FAILED | MARKETPLACE_ERROR | XML_ERROR | BARCODE_ERROR | STOCK_ERROR
  severity          String    @default("MEDIUM") // CRITICAL | HIGH | MEDIUM | LOW
  priority          Int       @default(3) // 1-5
  confidence        Float?
  title             String?
  description       String?
  recommendedAction String?
  approved          Boolean   @default(false)
  resolved          Boolean   @default(false)
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())

  @@index([productId])
  @@index([module])
  @@index([severity])
  @@index([resolved])
}

model AIRecommendation {
  id          String    @id @default(uuid())
  issueId     String
  provider    String    @default("ai")
  prompt      String?
  response    String?
  confidence  Float?
  approved    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([issueId])
}
