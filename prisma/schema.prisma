generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      String    @default("OPERATOR")
  name      String?
  createdAt DateTime  @default(now())
  auditLogs AuditLog[]
  preferences String? // JSON: kullanıcı tercihleri (sayfa başına göster, sütun ayarları vb.)
}

model Marketplace {
  id                     String                  @id @default(uuid())
  key                    String                  @unique
  name                   String
  apiKey                 String?
  apiSecret              String?
  apiUrl                 String?
  apiStatus              String                  @default("unknown")
  active                 Boolean                 @default(true)
  settings               String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  productMarketplaceStates ProductMarketplaceState[]
  orders                 Order[]
  messages               Message[]
  templates              ListingTemplate[]
  financeRecords         FinanceRecord[]
}

model Product {
  id                     String                  @id @default(uuid())
  xmlKey                 String                  @unique
  title                  String?
  seoTitle               String?
  seoDescription         String?
  description            String?
  technicalSpecs         String?
  images                 String?
  videos                 String?
  sku                    String?
  barcode                String?
  stockCode              String?
  categoryId             String?
  category               Category?               @relation(fields: [categoryId], references: [id])
  brandId                String?
  brand                  Brand?                  @relation(fields: [brandId], references: [id])
  categoryMatch          Boolean                 @default(false)
  variantMatch           Boolean                 @default(false)
  brandMatch             Boolean                 @default(false)
  templateMatch          Boolean                 @default(false)
  stock                  Int                     @default(0)
  minStock               Int                     @default(0)
  purchasePrice          Float?
  salePrice              Float?
  vatRate                Float?
  commissionRate         Float?
  profitMargin           Float?
  minProfit              Float?
  discount               Float?
  status                 String                  @default("XML")
  errorMessage           String?
  tags                   String?
  xmlSourceId            String?
  link                   String?                 // Ürün linki
  unit                   String?                 // Birim (Adet, kg vb.)
  currency               String?                 // Para birimi
  detail                 String?                 // Detaylı açıklama
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  marketplaceStates      ProductMarketplaceState[]
  variants               Variant[]
  xmlSource              XmlSource?              @relation(fields: [xmlSourceId], references: [id])
}

model ProductMarketplaceState {
  id             String        @id @default(uuid())
  productId      String
  marketplaceId  String
  status         String        @default("XML")
  listingId      String?
  listingUrl     String?
  lastActionAt   DateTime?
  externalRef    String?
  price          Float?
  stock          Int?
  errorMessage   String?

  product       Product       @relation(fields: [productId], references: [id])
  marketplace   Marketplace   @relation(fields: [marketplaceId], references: [id])

  @@unique([productId, marketplaceId])
}

model QueueJob {
  id            String   @id @default(uuid())
  jobType       String
  idempotencyKey String  @unique
  status        String   @default("queued")
  attempts      Int      @default(0)
  lastError     String?
  payload       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model XmlSource {
  id                      String           @id @default(uuid())
  name                    String
  company                 String?
  sourceType              String           @default("MANUAL")
  url                     String?
  username                String?
  password                String?
  currency                String           @default("TRY")
  vatRate                 Float            @default(20)
  updateStock             Boolean          @default(true)
  updatePrice             Boolean          @default(true)
  updateImages            Boolean          @default(true)
  active                  Boolean          @default(true)
  scheduleIntervalMinutes Int              @default(60)
  cronExpression          String?
  lastRunAt               DateTime?
  lastSuccessAt           DateTime?
  lastError               String?
  connectionStatus        String           @default("unknown") // "connected", "error", "auth_error", "timeout", "unknown"
  
  // KDV Yönetimi
  purchasePriceVatStatus  String           @default("dahil") // "dahil", "haric", "ekleme"
  
  // Fiyatlandırma Motoru Ayarları (JSON)
  pricingRules            String?          // JSON: fiyatlandırma kuralları dizisi
  
  // XML Alan Eşleştirme (JSON)
  fieldMapping            String?          // JSON: { "xml_field": "system_field", ... }
  
  // Alış fiyatı alanı seçimi
  purchasePriceField      String?          // XML'deki hangi alanın alış fiyatı olarak kullanılacağı
  
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  importRuns              XmlImportRun[]
  products                Product[]
}

model XmlImportRun {
  id                  String                 @id @default(uuid())
  sourceId            String
  startedAt           DateTime               @default(now())
  finishedAt          DateTime?
  durationMs          Int?
  status              String                 @default("running")
  totalProducts       Int                    @default(0)
  newProducts         Int                    @default(0)
  updatedProducts     Int                    @default(0)
  failedProducts      Int                    @default(0)
  skippedProducts     Int                    @default(0)
  deletedProducts     Int                    @default(0)
  errorDetail         String?
  source              XmlSource              @relation(fields: [sourceId], references: [id])
  itemResults         XmlImportItemResult[]
}

model XmlImportItemResult {
  id              String        @id @default(uuid())
  importRunId     String
  xmlKey          String
  sku             String?
  outcome         String        @default("created")
  errorDetail     String?
  createdAt       DateTime      @default(now())
  importRun       XmlImportRun  @relation(fields: [importRunId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  entity      String?
  entityId    String?
  meta        String?
  details     String?
  ipAddress   String?
  duration    Int?
  success     Boolean  @default(true)
  createdAt   DateTime @default(now())

  actorUser   User? @relation(fields: [actorUserId], references: [id])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  externalId  String?
  parentId    String?
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Brand {
  id          String    @id @default(uuid())
  name        String    @unique
  externalId  String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Variant {
  id          String    @id @default(uuid())
  name        String
  value       String
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, name, value])
}

model Order {
  id            String    @id @default(uuid())
  orderNo       String    @unique
  channel       String
  marketplaceId String?
  marketplace   Marketplace? @relation(fields: [marketplaceId], references: [id])
  customerName  String
  customerEmail String?
  customerPhone String?
  address       String?
  city          String?
  district      String?
  cargoCompany  String?
  trackingNo    String?
  status        String    @default("new")
  total         Float
  cargoPrice    Float?
  commission    Float?
  vat           Float?
  notes         String?
  items         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  shipments     Shipment[]
  financeRecords FinanceRecord[]
}

model Shipment {
  id            String    @id @default(uuid())
  orderId       String?
  order         Order?    @relation(fields: [orderId], references: [id])
  channel       String
  cargoCompany  String
  trackingNo    String
  status        String    @default("queued")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Message {
  id            String    @id @default(uuid())
  marketplaceId String?
  marketplace   Marketplace? @relation(fields: [marketplaceId], references: [id])
  customerName  String
  customerEmail String?
  subject       String
  message       String
  aiSuggestion  String?
  status        String    @default("unread")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Notification {
  id          String    @id @default(uuid())
  type        String
  title       String
  message     String
  read        Boolean   @default(false)
  userId      String?
  createdAt   DateTime  @default(now())
}

model ListingTemplate {
  id            String    @id @default(uuid())
  name          String
  marketplaceId String?
  marketplace   Marketplace? @relation(fields: [marketplaceId], references: [id])
  titleFormat   String?
  description   String?
  priceFormula  String?
  commissionRate Float?
  vatRate       Float?
  cargoSettings String?
  imageSettings String?
  categoryId    String?
  brandId       String?
  variantSettings String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model AutomationRule {
  id            String    @id @default(uuid())
  name          String
  type          String    // "xml_sync", "price_update", "stock_update", "order_sync", "cargo_sync", "notification"
  triggerType   String    // "schedule", "webhook", "cron", "event"
  triggerConfig String?   // JSON: schedule interval, cron expression, webhook URL etc.
  actionType    String    // "sync_xml", "update_price", "update_stock", "sync_order", "send_notification"
  actionConfig  String?   // JSON: action-specific configuration
  active        Boolean   @default(true)
  schedule      String?   // Cron expression or interval string
  marketplaceId String?
  lastRunAt     DateTime?
  lastSuccessAt DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model FinanceRecord {
  id            String      @id @default(uuid())
  type          String      @default("sale")
  amount        Float
  commission    Float?
  vat           Float?
  profit        Float?
  productId     String?
  marketplaceId String?
  marketplace   Marketplace? @relation(fields: [marketplaceId], references: [id])
  orderId       String?
  order         Order?      @relation(fields: [orderId], references: [id])
  description   String?
  date          DateTime    @default(now())
  createdAt     DateTime    @default(now())
}
