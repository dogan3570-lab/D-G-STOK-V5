generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      String    @default("OPERATOR")
  createdAt DateTime  @default(now())
  auditLogs AuditLog[]
}

model Marketplace {
  id                     String                  @id @default(uuid())
  key                    String                  @unique
  name                   String
  apiStatus              String                  @default("unknown")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  productMarketplaceStates ProductMarketplaceState[]
}

model Product {
  id                     String                  @id @default(uuid())
  xmlKey                 String                  @unique
  title                  String?
  sku                    String?
  barcode                String?
  categoryId             String?
  category               Category?               @relation(fields: [categoryId], references: [id])
  brandId                String?
  brand                  Brand?                  @relation(fields: [brandId], references: [id])
  categoryMatch          Boolean                 @default(false)
  variantMatch           Boolean                 @default(false)
  brandMatch             Boolean                 @default(false)
  templateMatch          Boolean                 @default(false)
  stock                  Int                     @default(0)
  minStock               Int                     @default(0)
  status                 String                  @default("XML")
  errorMessage           String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  marketplaceStates      ProductMarketplaceState[]
  variants               Variant[]
}

model ProductMarketplaceState {
  id             String        @id @default(uuid())
  productId      String
  marketplaceId  String
  status         String        @default("XML")
  lastActionAt   DateTime?
  externalRef    String?

  product       Product       @relation(fields: [productId], references: [id])
  marketplace   Marketplace   @relation(fields: [marketplaceId], references: [id])

  @@unique([productId, marketplaceId])
}

model QueueJob {
  id            String   @id @default(uuid())
  jobType       String
  idempotencyKey String  @unique
  status        String   @default("queued")
  attempts      Int      @default(0)
  lastError     String?
  payload       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model XmlSource {
  id                      String           @id @default(uuid())
  name                    String
  sourceType              String           @default("MANUAL")
  url                     String?
  active                  Boolean          @default(true)
  scheduleIntervalMinutes Int              @default(60)
  lastRunAt               DateTime?
  lastSuccessAt           DateTime?
  lastError               String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  importRuns              XmlImportRun[]
}

model XmlImportRun {
  id                  String                 @id @default(uuid())
  sourceId            String
  startedAt           DateTime               @default(now())
  finishedAt          DateTime?
  durationMs          Int?
  status              String                 @default("running")
  totalProducts       Int                    @default(0)
  newProducts         Int                    @default(0)
  updatedProducts     Int                    @default(0)
  failedProducts      Int                    @default(0)
  skippedProducts     Int                    @default(0)
  errorDetail         String?
  source              XmlSource              @relation(fields: [sourceId], references: [id])
  itemResults         XmlImportItemResult[]
}

model XmlImportItemResult {
  id              String        @id @default(uuid())
  importRunId     String
  xmlKey          String
  sku             String?
  outcome         String        @default("created")
  errorDetail     String?
  createdAt       DateTime      @default(now())
  importRun       XmlImportRun  @relation(fields: [importRunId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  meta         String?
  createdAt   DateTime @default(now())

  actorUser   User? @relation(fields: [actorUserId], references: [id])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  externalId  String?
  parentId    String?
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Brand {
  id          String    @id @default(uuid())
  name        String    @unique
  externalId  String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Variant {
  id          String    @id @default(uuid())
  name        String
  value       String
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, name, value])
}

model Order {
  id          String    @id @default(uuid())
  orderNo     String    @unique
  channel     String
  customerName String
  status      String    @default("new")
  total       Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Shipment {
  id            String    @id @default(uuid())
  orderId       String?
  channel       String
  cargoCompany  String
  trackingNo    String
  status        String    @default("queued")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
